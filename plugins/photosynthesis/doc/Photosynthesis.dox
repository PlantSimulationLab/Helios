 <tr><td>Gamma\_CO2</td><td>\f$\Gamma\f$</td><td>\f$\mu\f$mol CO<sub>2</sub>/mol</td><td>\htmlonly<span style="font-family: Courier, monospace; color: green;">float</span>\endhtmlonly</td><td>Farquhar (C<sub>3</sub>)</td><td>Photosynthetic CO<sub>2</sub> compensation point (including "dark respiration").</td></tr>
 <tr><td>limitation\_state</td><td>N/A</td><td>N/A</td><td>\htmlonly<span style="font-family: Courier, monospace; color: green;">int</span>\endhtmlonly</td><td>Farquhar (C<sub>3</sub>), C<sub>4</sub></td><td>Photosynthesis limitation state. For the C<sub>3</sub> Farquhar model: 0 = Rubisco-limited, 1 = electron-transport-limited. For the C<sub>4</sub> model: 1 = enzyme (\f$A_c\f$) limited, 2 = electron-transport (\f$A_j\f$) limited.</td></tr>
 <tr><td>electron\_transport\_ratio</td><td>\f$J/J_{max}\f$</td><td>unitless</td><td>\htmlonly<span style="font-family: Courier, monospace; color: green;">float</span>\endhtmlonly</td><td>Farquhar (C<sub>3</sub>)</td><td>Ratio of actual electron transport rate to maximum electron transport rate. Ranges from 0 (dark) to ~1 (light-saturated). Useful for computing fluorescence quantum yield.</td></tr>
 <tr><td>Cm</td><td>\f$C_m\f$</td><td>\f$\mu\f$bar</td><td>\htmlonly<span style="font-family: Courier, monospace; color: green;">float</span>\endhtmlonly</td><td>C<sub>4</sub></td><td>Mesophyll cytosolic CO<sub>2</sub> partial pressure, \f$C_m = C_i - A/g_m\f$.</td></tr>
